rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles ─────────────────────────────────────────────────
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Game rooms ────────────────────────────────────────────────────
    match /rooms/{roomId} {

      allow read: if request.auth != null;

      // ── Create ───────────────────────────────────────────────────────
      allow create: if request.auth != null
        && request.resource.data.hostId      == request.auth.uid
        && request.resource.data.status      == 'waiting'
        && request.resource.data.winner      == null
        && request.resource.data.playerCount == 0
        && request.resource.data.calledNumbers.size() == 0
        && request.resource.data.gameMode    in ['auto', 'manual', 'classic25']
        && request.resource.data.turnOrderMode in ['random', 'rps']
        && request.resource.data.winPattern  is string;

      // ── Update ───────────────────────────────────────────────────────
      allow update: if request.auth != null && (
          hostCanUpdate()
        || playerCanJoin()
        || playerCanWin()
        || callerCanCall()
        || playerCanChooseRPS()
      );

      // ── Delete ───────────────────────────────────────────────────────
      allow delete: if request.auth != null
        && resource.data.hostId == request.auth.uid
        && resource.data.status == 'waiting';

      // ─── Functions ──────────────────────────────────────────────────

      // HOST: broad update rights with safety rails
      function hostCanUpdate() {
        let changed = request.resource.data.diff(resource.data).affectedKeys();
        return resource.data.hostId == request.auth.uid
          // Immutable after creation
          && !changed.hasAny(['hostId', 'hostName', 'gameMode', 'winPattern', 'turnOrderMode', 'createdAt'])
          // Status only advances
          && (!changed.hasAny(['status']) || validStatusStep())
          // calledNumbers only grows
          && (!changed.hasAny(['calledNumbers']) || calledGrowsByOne())
          // winner only set once
          && (!changed.hasAny(['winner']) || resource.data.winner == null)
          // Can't update a finished game
          && resource.data.status != 'finished';
      }

      // ANY player: increment playerCount by 1 when waiting
      function playerCanJoin() {
        let changed = request.resource.data.diff(resource.data).affectedKeys();
        return resource.data.status == 'waiting'
          && changed.hasOnly(['playerCount'])
          && request.resource.data.playerCount == resource.data.playerCount + 1;
      }

      // ANY player: declare win for themselves only
      function playerCanWin() {
        let changed = request.resource.data.diff(resource.data).affectedKeys();
        return resource.data.status  == 'playing'
          && resource.data.winner    == null
          && changed.hasOnly(['winner', 'winnerName', 'status'])
          && request.resource.data.status == 'finished'
          && request.resource.data.winner == request.auth.uid;
      }

      // MANUAL/CLASSIC25: current caller (non-host) calls next number
      function callerCanCall() {
        let changed = request.resource.data.diff(resource.data).affectedKeys();
        return resource.data.status          == 'playing'
          && resource.data.gameMode          in ['manual', 'classic25']
          && resource.data.currentCallerId   == request.auth.uid
          && changed.hasOnly([
               'calledNumbers', 'currentCallerId', 'currentCallerIndex',
               'lastCalledAt', 'callerTurnStartedAt'
             ])
          && calledGrowsByOne();
      }

      // Status advances only forward:
      // waiting → rps|playing, rps → playing, playing → finished
      function validStatusStep() {
        return (resource.data.status == 'waiting' && request.resource.data.status in ['playing', 'rps'])
            || (resource.data.status == 'rps'     && request.resource.data.status == 'playing')
            || (resource.data.status == 'playing' && request.resource.data.status == 'finished');
      }

      // ANY player: submit their RPS choice into room.rpsChoices map
      function playerCanChooseRPS() {
        let changed = request.resource.data.diff(resource.data).affectedKeys();
        return resource.data.status == 'rps'
          && changed.hasOnly(['rpsChoices'])
          && resource.data.rpsChoices.get(request.auth.uid, null) == null
          && request.resource.data.rpsChoices.get(request.auth.uid, null)
               in ['rock', 'paper', 'scissors'];
      }

      // calledNumbers grows by exactly 1 and retains all prior entries
      function calledGrowsByOne() {
        return request.resource.data.calledNumbers.size() == resource.data.calledNumbers.size() + 1
          && request.resource.data.calledNumbers.size() <= 75
          && request.resource.data.calledNumbers.toSet()
               .hasAll(resource.data.calledNumbers.toSet());
      }

      // ── Players sub-collection ────────────────────────────────────
      match /players/{uid} {
        allow read: if request.auth != null;

        // CREATE own doc while room is waiting; clean initial state
        allow create: if request.auth != null
          && request.auth.uid == uid
          && get(/databases/$(database)/documents/rooms/$(roomId)).data.status == 'waiting'
          && request.resource.data.uid          == uid
          && request.resource.data.markedNumbers.size() == 0
          && request.resource.data.hasBingo     == false;

        // UPDATE own doc — mark numbers during play
        allow update: if request.auth != null
          && request.auth.uid == uid
          && playerMark();

        // Mark numbers during active game
        function playerMark() {
          let roomData = get(/databases/$(database)/documents/rooms/$(roomId)).data;
          let changed  = request.resource.data.diff(resource.data).affectedKeys();
          return roomData.status == 'playing'
            && changed.hasOnly(['markedNumbers', 'hasBingo'])
            // append-only markedNumbers
            && request.resource.data.markedNumbers.toSet()
                 .hasAll(resource.data.markedNumbers.toSet())
            // can only mark called numbers
            && roomData.calledNumbers.toSet()
                 .hasAll(request.resource.data.markedNumbers.toSet());
        }

      }
    }
  }
}
